public class QuestionnaireRequest {
    
    private String userId;
    private Feature preferences;

    // Costruttori
    public QuestionnaireRequest() {}

    // Getters e Setters
    public String getUserId() {
        return userId;
    }

    public void setUserId(String userId) {
        this.userId = userId;
    }

    public Feature getPreferences() {
        return preferences;
    }

    public void setPreferences(Feature preferences) {
        this.preferences = preferences;
    }
}
